      "parameters": {
        "jsCode": "const body = $('Webhook - Receive Return Data').first().json.body;\n\n// ✅ GROQ response path (was message.content before — that was OpenAI format)\nconst aiResponse = $input.first().json.choices[0].message.content;\n\nlet parsed;\ntry {\n  const cleaned = aiResponse.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    category: 'Other',\n    sentiment: 'Neutral',\n    severity: 1,\n    summary: 'Unable to parse AI response.'\n  };\n}\n\nconst timestamp = new Date().toISOString();\n\nreturn {\n  order_id: body.order_id || '',\n  customer_name: body.customer_name || '',\n  email: body.email || '',\n  product_name: body.product_name || '',\n  category: parsed.category || 'Other',\n  sentiment: parsed.sentiment || 'Neutral',\n  severity: parseInt(parsed.severity) || 1,\n  summary: parsed.summary || '',\n  timestamp: timestamp\n};"
      },
