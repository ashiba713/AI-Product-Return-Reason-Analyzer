    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COUNT(*) AS total_returns,\n  MODE() WITHIN GROUP (ORDER BY category) AS most_common_category,\n  AVG(severity) AS avg_severity,\n  MAX(severity) AS max_severity\nFROM product_return_insights\nWHERE timestamp >= NOW() - INTERVAL '24 hours';",
        "options": {}
      },
      "id": "c0982839-e5da-4554-8d8d-3ee707f6842d",
      "name": "Postgres - Aggregate Daily Stats",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        -720,
        528
      ],
      "credentials": {
        "postgres": {
