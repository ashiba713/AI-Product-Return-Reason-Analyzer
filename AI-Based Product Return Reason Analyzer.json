    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  product_name,\n  COUNT(*) AS return_count,\n  AVG(severity) AS avg_severity,\n  MAX(severity) AS max_severity,\n  MODE() WITHIN GROUP (ORDER BY category) AS top_category\nFROM product_return_insights\nWHERE timestamp >= NOW() - INTERVAL '24 hours'\nGROUP BY product_name\nORDER BY avg_severity DESC, return_count DESC\nLIMIT 10;",
        "options": {}
      },
      "id": "648c1d15-b9f5-4ae3-897a-9d4f03ae2cfd",
      "name": "Postgres - Top Products by Severity",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        -480,
        528
      ],
      "credentials": {
        "postgres": {
          "id": "ejOSzz7gjk9Nbhpi",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const stats = $('Postgres - Aggregate Daily Stats').first().json;\nconst topProducts = $('Postgres - Top Products by Severity').all().map(item => item.json);\n\nconst reportDate = new Date().toLocaleDateString('en-US', {\n  weekday: 'long',\n  year: 'numeric',\n  month: 'long',\n  day: 'numeric'\n});\n\nlet productsTableRows = '';\nif (topProducts.length === 0) {\n  productsTableRows = '<tr><td colspan=\"5\" style=\"text-align:center; padding: 12px; color: #6c757d;\">No returns recorded in the last 24 hours</td></tr>';\n} else {\n  topProducts.forEach(p => {\n    const severityColor = p.max_severity >= 4 ? '#dc3545' : p.max_severity >= 3 ? '#fd7e14' : '#28a745';\n    productsTableRows += `<tr>\n      <td style=\"padding: 10px; border-bottom: 1px solid #dee2e6;\">${p.product_name}</td>\n      <td style=\"padding: 10px; border-bottom: 1px solid #dee2e6; text-align:center;\">${p.return_count}</td>\n      <td style=\"padding: 10px; border-bottom: 1px solid #dee2e6; text-align:center;\">${parseFloat(p.avg_severity).toFixed(1)}</td>\n      <td style=\"padding: 10px; border-bottom: 1px solid #dee2e6; text-align:center; color: ${severityColor}; font-weight:bold;\">${p.max_severity}</td>\n      <td style=\"padding: 10px; border-bottom: 1px solid #dee2e6;\">${p.top_category}</td>\n    </tr>`;\n  });\n}\n\nconst htmlReport = `<html><body style=\"font-family: Arial, sans-serif; max-width: 700px; margin: 0 auto; color: #333;\">\n<div style=\"background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; border-radius: 8px 8px 0 0;\">\n  <h1 style=\"margin: 0; font-size: 24px;\">📊 Daily Return Analytics Report</h1>\n  <p style=\"margin: 8px 0 0 0; opacity: 0.9;\">${reportDate}</p>\n</div>\n<div style=\"background: #f8f9fa; padding: 25px; border: 1px solid #dee2e6;\">\n  <h2 style=\"color: #495057; margin-top: 0;\">📈 24-Hour Summary</h2>\n  <div style=\"display: flex; gap: 15px; flex-wrap: wrap;\">\n    <div style=\"background: white; padding: 20px; border-radius: 8px; border: 1px solid #dee2e6; flex: 1; min-width: 140px; text-align: center;\">\n      <div style=\"font-size: 36px; font-weight: bold; color: #667eea;\">${stats.total_returns || 0}</div>\n      <div style=\"color: #6c757d; font-size: 14px; margin-top: 5px;\">Total Returns</div>\n    </div>\n    <div style=\"background: white; padding: 20px; border-radius: 8px; border: 1px solid #dee2e6; flex: 1; min-width: 140px; text-align: center;\">\n      <div style=\"font-size: 24px; font-weight: bold; color: #fd7e14;\">${stats.most_common_category || 'N/A'}</div>\n      <div style=\"color: #6c757d; font-size: 14px; margin-top: 5px;\">Top Category</div>\n    </div>\n    <div style=\"background: white; padding: 20px; border-radius: 8px; border: 1px solid #dee2e6; flex: 1; min-width: 140px; text-align: center;\">\n      <div style=\"font-size: 36px; font-weight: bold; color: #28a745;\">${stats.avg_severity ? parseFloat(stats.avg_severity).toFixed(1) : '0.0'}</div>\n      <div style=\"color: #6c757d; font-size: 14px; margin-top: 5px;\">Avg Severity</div>\n    </div>\n    <div style=\"background: white; padding: 20px; border-radius: 8px; border: 1px solid #dee2e6; flex: 1; min-width: 140px; text-align: center;\">\n      <div style=\"font-size: 36px; font-weight: bold; color: #dc3545;\">${stats.max_severity || 0}</div>\n      <div style=\"color: #6c757d; font-size: 14px; margin-top: 5px;\">Max Severity</div>\n    </div>\n  </div>\n</div>\n<div style=\"background: white; padding: 25px; border: 1px solid #dee2e6;\">\n  <h2 style=\"color: #495057; margin-top: 0;\">🏆 Products with Highest Return Severity</h2>\n  <table style=\"width: 100%; border-collapse: collapse; font-size: 14px;\">\n    <thead>\n      <tr style=\"background: #667eea; color: white;\">\n        <th style=\"padding: 12px; text-align: left;\">Product Name</th>\n        <th style=\"padding: 12px; text-align: center;\">Returns</th>\n        <th style=\"padding: 12px; text-align: center;\">Avg Severity</th>\n        <th style=\"padding: 12px; text-align: center;\">Max Severity</th>\n        <th style=\"padding: 12px; text-align: left;\">Top Category</th>\n      </tr>\n    </thead>\n    <tbody>\n      ${productsTableRows}\n    </tbody>\n  </table>\n</div>\n<div style=\"background: #f8f9fa; padding: 20px; border: 1px solid #dee2e6; border-radius: 0 0 8px 8px;\">\n  <p style=\"color: #6c757d; font-size: 12px; text-align: center; margin: 0;\">Generated automatically by Product Return Analyzer | ${new Date().toISOString()}</p>\n</div>\n</body></html>`;\n\nreturn {\n  subject: `Daily Return Analytics Report - ${reportDate} | ${stats.total_returns || 0} Returns`,\n  htmlReport,\n  reportDate,\n  stats\n};"
      },
